    s.style.color = 'var(--green)'; s.textContent = '✅ Upload OK — ESP32 acknowledged — mission queued';
  }, 1400);
}

// ================================================================
//  EXPORT
// ================================================================
function doCSV() {
  const hdr = 'run,run_label,loop,elapsed_ms,depth_m,temp_c,pressure_mbar,dp_mbar,mode,turb_vavg_v,turb_raw_adc,ntu_est,gps_fix,satellites,servo_state,valve_state,mission_state,sample_triggered';
  const rows = [];
  Object.entries(RUNS).forEach(([run, R]) => {
    R.rows.forEach((row, i) => {
      const [ms, depth, temp, pres, dp, vavg, raw, ntu, mode, state, servo, valve] = row;
      const trig = i > 0 && servo === 'CLOSED' && R.rows[i-1][10] === 'OPEN';
      rows.push(`${run},"${R.label}",${i+1},${ms},${depth.toFixed(3)},${temp.toFixed(2)},${pres.toFixed(1)},${dp.toFixed(1)},${mode},${vavg.toFixed(3)},${raw},${ntu.toFixed(1)},FALSE,0,${servo},${valve},${state},${trig}`);
    });
  });
  dl(hdr + '\n' + rows.join('\n'), 'AquaCast_Lab_AllRuns_20260211.csv', 'text/csv');
}

function doJSON() {
  const out = {};
  Object.entries(RUNS).forEach(([run, R]) => {
    out[run] = {
      mission_id: R.id, label: R.label, condition: R.cond,
      start_time: R.t0, device_id: 'ESP32_LORA_01',
      location: 'UW GIX Lab 203', container: '40cm plastic bin',
      owner: 'Victoria Yang', firmware: 'AquaCast v0.3',
      samples: R.rows.map((row, i) => {
        const [ms, depth, temp, pres, dp, vavg, raw, ntu, mode, state, servo, valve] = row;
        return { loop:i+1, elapsed_ms:ms, depth_m:depth, temp_c:temp,
                 pressure_mbar:pres, dp_mbar:dp, turb_vavg_v:vavg, turb_raw_adc:raw,
                 ntu_est:ntu, mode, mission_state:state, servo_state:servo,
                 valve_state:valve, gps_fix:false, satellites:0 };
      })
    };
  });
  dl(JSON.stringify(out, null, 2), 'AquaCast_Lab_AllRuns_20260211.json', 'application/json');
}

function dl(content, filename, type) {
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([content], { type }));
  a.download = filename; a.click();
}

// ================================================================
//  INIT
// ================================================================
window.onload = () => {
  initCharts();
  refreshJSON();
  renderSerial('A');
};
