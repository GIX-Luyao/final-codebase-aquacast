// ================================================================
//  GLOBALS
// ================================================================
let activeRun = 'A';
let timer = null;
let idx = 0;
let charts = {};

// ================================================================
//  PAGE NAV
// ================================================================
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  const labels = ['live','serial','config','export'];
  document.querySelectorAll('.nav-tab').forEach((t,i) => t.classList.toggle('active', labels[i] === name));
  if (name === 'serial') renderSerial(activeRun);
  if (name === 'config') refreshJSON();
}

// ================================================================
//  RUN SWITCHING
// ================================================================
function switchRun(r) {
  activeRun = r;
  if (timer) { clearInterval(timer); timer = null; }
  ['A','B','C'].forEach(x => document.getElementById('rb'+x).classList.toggle('active', x === r));
  const R = RUNS[r];
  document.getElementById('missionId').textContent = R.id;
  document.getElementById('statusTxt').textContent = 'READY — ' + R.label.toUpperCase();
  document.getElementById('condBadgeEl').innerHTML = `<span class="cond-badge ${R.condCls}">${R.cond}</span>`;
  document.getElementById('condSrc').textContent = R.src;
  document.getElementById('condAmb').textContent = R.amb;
  clearCharts();
  resetSidebar();
  document.getElementById('logBody').innerHTML = '<tr><td colspan="12" style="text-align:center;padding:18px;color:var(--light-slate);">Press ▶ Replay to stream data</td></tr>';
}

// ================================================================
//  CHARTS
// ================================================================
function makeChart(id, color, yLabel, invertY) {
  const ctx = document.getElementById(id).getContext('2d');
  const cfg = {
    type:'line',
    data:{ labels:[], datasets:[{ data:[], borderColor:color, backgroundColor:color+'18',
           borderWidth:2, pointRadius:2, tension:0.4, fill:true }] },
    options:{
      responsive:true, maintainAspectRatio:false, animation:false,
      plugins:{ legend:{ display:false } },
      scales:{
        x:{ ticks:{ font:{size:9}, maxTicksLimit:8 }, grid:{ color:'rgba(0,0,0,.05)' } },
        y:{ reverse: !!invertY,
            title:{ display:true, text:yLabel, font:{size:9} },
            ticks:{ font:{size:9} }, grid:{ color:'rgba(0,0,0,.05)' } }
      }
    }
  };
  return new Chart(ctx, cfg);
}

function initCharts() {
  charts.depth = makeChart('cDepth', '#1C7293', 'm', true);
  charts.temp  = makeChart('cTemp',  '#00A896', '°C');
  charts.turb  = makeChart('cTurb',  '#F59E0B', 'NTU');
  charts.pres  = makeChart('cPres',  '#065A82', 'mbar');
}

function clearCharts() {
  Object.values(charts).forEach(c => {
    c.data.labels = []; c.data.datasets[0].data = []; c.update('none');
  });
}

function pushChart(label, d, t, n, p) {
  const MAX = 35;
  [[charts.depth, d],[charts.temp, t],[charts.turb, n],[charts.pres, p]].forEach(([c, v]) => {
    c.data.labels.push(label); c.data.datasets[0].data.push(v);
    if (c.data.labels.length > MAX) { c.data.labels.shift(); c.data.datasets[0].data.shift(); }
    c.update('none');
  });
}

// ================================================================
//  REPLAY
// ================================================================
function replay() {
  if (timer) { clearInterval(timer); timer = null; }
  clearCharts();
  resetSidebar();
  document.getElementById('logBody').innerHTML = '';
  idx = 0;
  const R = RUNS[activeRun];
  document.getElementById('statusTxt').textContent = 'STREAMING — ' + R.label.toUpperCase();

  timer = setInterval(() => {
    if (idx >= R.rows.length) {
      clearInterval(timer); timer = null;
      document.getElementById('statusTxt').textContent = 'COMPLETE — ' + R.label;
      setAlert('ok', '✅ Run complete — ' + R.rows.length + ' loops logged — max depth ' + Math.max(...R.rows.map(r=>r[1])).toFixed(3) + ' m');
      setPhase('COMPLETE');
      return;
    }
    const row = R.rows[idx];
    const [ms, depth, temp, pres, dp, vavg, raw, ntu, mode, state, servo, valve] = row;
    const isSampleTrigger = idx > 0 && servo === 'CLOSED' && R.rows[idx-1][10] === 'OPEN';
    const loop = idx + 1;

    // Sidebar live readings
    document.getElementById('sDepth').textContent = depth.toFixed(3) + ' m';
    document.getElementById('sTemp').textContent  = temp.toFixed(1) + ' °C';
    document.getElementById('sPres').textContent  = pres.toFixed(1) + ' mbar';
    document.getElementById('sDp').textContent    = (dp >= 0 ? '+' : '') + dp.toFixed(1);
    document.getElementById('sNtu').textContent   = ntu.toFixed(1) + ' NTU';
    document.getElementById('sVavg').textContent  = vavg.toFixed(3) + ' V';
    document.getElementById('sLoop').textContent  = loop;
    document.getElementById('sMode').textContent  = mode;
    document.getElementById('sState').textContent = state;
    document.getElementById('sServo').textContent = servo;
    document.getElementById('sServo').className   = 'mm-val ' + (servo === 'CLOSED' ? 'mm-warn' : 'mm-ok');
    document.getElementById('sValve').textContent = valve;
    document.getElementById('sValve').className   = 'mm-val ' + (valve !== 'OFF' ? 'mm-warn' : '');

    // Count sample triggers
    let scnt = 0;
    for (let i = 1; i <= idx; i++) if (R.rows[i][10] === 'CLOSED' && R.rows[i-1][10] === 'OPEN') scnt++;
    document.getElementById('sSamples').textContent = scnt + ' / 2';
    document.getElementById('mSamples').textContent = scnt;
    document.getElementById('mLoops').textContent = loop;

    // Summary metrics
    const allD = R.rows.slice(0, idx+1).map(r => r[1]);
    const allT = R.rows.slice(0, idx+1).map(r => r[2]);
    const allN = R.rows.slice(0, idx+1).map(r => r[7]);
    const allP = R.rows.slice(0, idx+1).map(r => r[3]);
    document.getElementById('mMaxDepth').textContent = Math.max(...allD).toFixed(3);
    document.getElementById('mMinTemp').textContent  = Math.min(...allT).toFixed(1);
    document.getElementById('mAvgNtu').textContent   = (allN.reduce((a,b)=>a+b,0)/allN.length).toFixed(1);
    document.getElementById('mMaxPres').textContent  = Math.max(...allP).toFixed(1);

    // Phase
    setPhase(state);

    // Alert
    if (depth > 0.38) setAlert('warn', '⚠ Depth nearing container limit — ' + (depth*100).toFixed(0) + ' cm');
    else if (state === 'SAMPLING') setAlert('ok', '✅ SAMPLING at ' + depth.toFixed(3) + ' m — ' + temp.toFixed(1) + '°C — ' + ntu.toFixed(1) + ' NTU');
    else if (isSampleTrigger) setAlert('ok', '✅ Sample triggered — servo CLOSED — chamber sealed');
    else setAlert('ok', '✅ ' + state + ' | depth ' + depth.toFixed(3) + ' m | loop ' + loop);

    // Chart
    pushChart((ms/1000).toFixed(1) + 's', depth, temp, ntu, pres);

    // Table row
    const tb = document.getElementById('logBody');
    const tr = document.createElement('tr');
    if (isSampleTrigger) tr.className = 'log-sample';
    tr.innerHTML = `
      <td>${loop}</td>
      <td style="color:#58a6ff;font-family:monospace">${(ms/1000).toFixed(3)}s</td>
      <td>${depth.toFixed(3)}</td>
      <td>${temp.toFixed(1)}</td>
      <td>${pres.toFixed(1)}</td>
      <td>${(dp>=0?'+':'')+dp.toFixed(1)}</td>
      <td>${vavg.toFixed(3)}</td>
      <td>${ntu.toFixed(1)}</td>
      <td>${mode}</td>
      <td style="${state==='SAMPLING'?'color:var(--seafoam);font-weight:700':''}">${state}</td>
      <td class="${isSampleTrigger?'sample-mark':''}">${servo}</td>
      <td>${valve}</td>`;
    tb.appendChild(tr);
    tb.parentElement.parentElement.scrollTop = 9999;

    idx++;
  }, 550);
}

const PHASE_MAP = { INIT:0, READY:1, DESCENT:2, SAMPLING:3, SURFACING:4, COMPLETE:5 };
function setPhase(state) {
  const n = PHASE_MAP[state] ?? 0;
  for (let i = 0; i < 6; i++) {
    const el = document.getElementById('ph' + i);
    el.className = 'phase ' + (i < n ? 'ph-done' : i === n ? 'ph-active' : 'ph-future');
  }
}

function resetSidebar() {
  ['sDepth','sTemp','sPres','sDp','sNtu','sVavg','sLoop'].forEach(id => document.getElementById(id).textContent = '—');
  document.getElementById('sSamples').textContent = '0 / 2';
  document.getElementById('sMode').textContent = 'AIR';
  document.getElementById('sState').textContent = 'IDLE';
  document.getElementById('sServo').textContent = 'OPEN';
  document.getElementById('sValve').textContent = 'OFF';
  ['mMaxDepth','mMinTemp','mAvgNtu','mMaxPres'].forEach(id => document.getElementById(id).textContent = '—');
  document.getElementById('mLoops').textContent = '0';
  document.getElementById('mSamples').textContent = '0';
  setPhase('INIT');
  setAlert('ok', '✅ System nominal — GPS: NO FIX (indoor lab, expected) — press ▶ Replay');
}

function setAlert(type, msg) {
  const el = document.getElementById('alertBar');
  el.className = 'alert-bar ' + { ok:'a-ok', warn:'a-warn', err:'a-err' }[type];
  el.textContent = msg;
}

// ================================================================
//  SERIAL LOG RENDERER
// ================================================================
function renderSerial(run) {
  const R = RUNS[run];
  const [h0, m0, s0] = R.t0.split(':').map(Number);
  const base = (h0*3600 + m0*60 + s0) * 1000;

  let html = `<span class="sh">AquaCast Firmware v0.3 — ESP32 NodeMCU-32S<br>`;
  html += `Baud: 115200 | GPIO34: ADC turbidity (11 dB attenuation)<br>`;
  html += `I2C scan: MS5837 @ 0x76 ✓  |  GPS UART: NEO-6M @ 9600 baud ✓<br>`;
  html += `ADC: SEN0189 analog turbidity ✓  |  LoRa SX1276: 915 MHz, init OK ✓<br>`;
  html += `─────────────────────────────────────────────────────────────────<br>`;
  html += `Test condition: ${R.cond}<br>`;
  html += `Water source: ${R.src}<br>`;
  html += `Container: 40 cm plastic bin  |  Max depth target: 35 cm<br>`;
  html += `Start time: ${R.t0}<br>`;
  html += `─────────────────────────────────────────────────────────────────<br><br></span>`;

  R.rows.forEach((row, i) => {
    const [ms, depth, temp, pres, dp, vavg, raw, ntu, mode, state, servo, valve] = row;
    const abs = base + ms;
    const hh  = String(Math.floor(abs/3600000)%24).padStart(2,'0');
    const mm  = String(Math.floor((abs%3600000)/60000)).padStart(2,'0');
    const ss  = String(Math.floor((abs%60000)/1000)).padStart(2,'0');
    const ms3 = String(abs%1000).padStart(3,'0');
    const ts  = `${hh}:${mm}:${ss}.${ms3}`;
    const dpS = (dp >= 0 ? '+' : '') + dp.toFixed(1);
    const isTrig = i > 0 && servo === 'CLOSED' && R.rows[i-1][10] === 'OPEN';

    html += `<span class="st">${ts}</span> <span class="sa">-></span> `;
    html += `<span class="sk">Depth(m):</span> <span class="sv">${depth.toFixed(3)}</span> <span class="ss">|</span> `;
    html += `<span class="sk">Temp(C):</span> <span class="sv">${temp.toFixed(2)}</span> <span class="ss">|</span> `;
    html += `<span class="sk">P(mbar):</span> <span class="sv">${pres.toFixed(1)}</span> <span class="ss">|</span> `;
    html += `<span class="sk">dP:</span> <span class="sv">${dpS}</span> <span class="ss">|</span> `;
    html += `<span class="sk">Mode:</span> <span class="sv">${mode}</span> <span class="ss">|</span> `;
    html += `<span class="sk">Turb(Vavg):</span> <span class="sv">${vavg.toFixed(3)} V</span> <span class="ss">|</span> `;
    html += `<span class="sk">RAW:</span> <span class="sv">${raw}</span> <span class="ss">|</span> `;
    html += `<span class="sk">NTU(est):</span> <span class="sv">${ntu.toFixed(1)}</span> <span class="ss">|</span> `;
    html += `<span class="sk">GPS:</span> <span class="sw">NO FIX</span> <span class="ss">|</span> `;
    html += `<span class="sk">Sats:</span> <span class="sv">0</span> <span class="ss">|</span> `;
    html += `<span class="sk">Servo:</span> <span class="sv">${servo}</span> <span class="ss">|</span> `;
    html += `<span class="sk">Valve:</span> <span class="sv">${valve}</span> <span class="ss">|</span> `;
    html += `<span class="sk">State:</span> <span class="sst">${state}</span>`;
    if (isTrig) html += `  <span class="sm">*** SAMPLE TRIGGERED — servo CLOSED — chamber sealed ***</span>`;
    html += `<br>`;
  });

  const depths = R.rows.map(r=>r[1]), temps = R.rows.map(r=>r[2]), ntus = R.rows.map(r=>r[7]);
  const maxD = Math.max(...depths).toFixed(3);
  const avgT = (temps.reduce((a,b)=>a+b,0)/temps.length).toFixed(2);
  const avgN = (ntus.reduce((a,b)=>a+b,0)/ntus.length).toFixed(1);

  html += `<br><span class="sh">─────────────────────────────────────────────────────────────────<br>`;
  html += `RUN COMPLETE | Loops: ${R.rows.length} | Max depth: ${maxD} m | Avg temp: ${avgT} °C | Avg NTU: ${avgN}<br>`;
  html += `GPS: NO FIX (indoor — expected) | LoRa: OK | I2C: OK | Battery: 3.82 V<br>`;
  html += `─────────────────────────────────────────────────────────────────</span>`;

  document.getElementById('serialBox').innerHTML = html;
  document.getElementById('sumLoops').textContent = R.rows.length;
  document.getElementById('sumDepth').textContent = maxD;
  document.getElementById('sumTemp').textContent  = avgT;
  document.getElementById('sumNtu').textContent   = avgN;
}

function switchSerialRun(r) {
  ['A','B','C'].forEach(x => document.getElementById('st'+x).classList.toggle('active', x === r));
  renderSerial(r);
}

