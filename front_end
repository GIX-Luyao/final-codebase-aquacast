<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AquaCast Mission Dashboard — Lab Integration Test</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --deep-blue:#065A82; --teal:#1C7293; --seafoam:#00A896; --mint:#02C39A;
  --dark-nav:#021C2B; --dark-card:#0A2E45;
  --slate:#475569; --light-slate:#94A3B8;
  --green:#22C55E; --amber:#F59E0B; --red:#EF4444; --purple:#A855F7;
  --off-white:#F0F7FA;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--off-white);color:var(--slate);}

/* NAV */
.topnav{background:var(--dark-nav);display:flex;align-items:center;justify-content:space-between;padding:0 24px;height:54px;box-shadow:0 2px 12px rgba(0,0,0,.35);}
.brand{display:flex;align-items:center;gap:10px;}
.brand-dot{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--seafoam),var(--mint));display:flex;align-items:center;justify-content:center;font-weight:900;color:#fff;font-size:13px;}
.brand-name{color:#fff;font-weight:700;font-size:17px;}
.brand-name span{color:var(--mint);}
.brand-sub{color:var(--light-slate);font-size:11px;margin-left:8px;}
.nav-tabs{display:flex;gap:3px;}
.nav-tab{padding:6px 15px;border-radius:6px;cursor:pointer;font-size:13px;color:var(--light-slate);border:none;background:transparent;transition:.15s;}
.nav-tab.active{background:var(--teal);color:#fff;font-weight:600;}
.nav-tab:hover:not(.active){background:rgba(255,255,255,.08);color:#fff;}
.status-pill{display:flex;align-items:center;gap:6px;background:rgba(2,195,154,.15);border:1px solid var(--mint);border-radius:20px;padding:3px 12px;}
.status-dot{width:7px;height:7px;border-radius:50%;background:var(--mint);animation:pulse 2s infinite;}
.status-txt{font-size:11px;color:var(--mint);font-weight:600;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.35;}}

/* MISSION BAR */
.mission-bar{background:linear-gradient(135deg,var(--dark-card),var(--deep-blue));padding:10px 24px;display:flex;align-items:center;gap:18px;flex-wrap:wrap;border-bottom:1px solid rgba(0,168,150,.2);}
.mission-id{color:var(--mint);font-weight:700;font-size:13px;letter-spacing:.4px;}
.mission-meta{color:var(--light-slate);font-size:11px;}
.mission-meta b{color:#fff;}
.spacer{flex:1;}
.run-btns{display:flex;gap:5px;align-items:center;}
.run-btns label{color:var(--light-slate);font-size:11px;}
.run-btn{padding:4px 13px;border-radius:16px;border:1px solid rgba(255,255,255,.2);background:transparent;color:var(--light-slate);font-size:11px;cursor:pointer;transition:.15s;}
.run-btn.active{border-color:var(--mint);color:var(--mint);background:rgba(2,195,154,.12);font-weight:700;}
.owner-tag{display:inline-flex;align-items:center;gap:4px;background:rgba(168,85,247,.1);border:1px solid rgba(168,85,247,.3);border-radius:12px;padding:3px 10px;font-size:11px;color:var(--purple);font-weight:600;}
.btn{padding:6px 16px;border-radius:6px;border:none;cursor:pointer;font-size:12px;font-weight:600;transition:.15s;}
.btn-primary{background:var(--seafoam);color:var(--dark-nav);}
.btn-primary:hover{background:var(--mint);}
.btn-outline{background:transparent;border:1px solid var(--teal);color:var(--teal);}
.btn-outline:hover{background:var(--teal);color:#fff;}
.btn:disabled{opacity:.45;cursor:not-allowed;}

/* ALERT */
.alert-bar{padding:7px 24px;font-size:12px;font-weight:600;display:flex;align-items:center;gap:7px;}
.a-ok  {background:rgba(34,197,94,.09); color:var(--green); border-bottom:1px solid rgba(34,197,94,.2);}
.a-warn{background:rgba(245,158,11,.09);color:var(--amber); border-bottom:1px solid rgba(245,158,11,.2);}
.a-err {background:rgba(239,68,68,.09); color:var(--red);   border-bottom:1px solid rgba(239,68,68,.2);}

/* PAGE VISIBILITY */
.page{display:none;}.page.active{display:block;}

/* ── LIVE VIEW ── */
.live-layout{padding:14px 24px;display:grid;grid-template-columns:248px 1fr;gap:14px;}
.sidebar{display:flex;flex-direction:column;gap:11px;}
.card{background:#fff;border-radius:9px;padding:13px;box-shadow:0 1px 5px rgba(0,0,0,.06);border:1px solid rgba(6,90,130,.09);}
.card-title{font-size:10px;font-weight:700;color:var(--teal);text-transform:uppercase;letter-spacing:.8px;margin-bottom:9px;}
.mm{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid rgba(6,90,130,.06);}
.mm:last-child{border-bottom:none;}
.mm-label{font-size:11px;color:var(--slate);}
.mm-val{font-size:12px;font-weight:700;color:var(--deep-blue);}
.mm-ok{color:var(--green);}.mm-warn{color:var(--amber);}.mm-err{color:var(--red);}
.sbadge{font-size:10px;font-weight:700;padding:2px 7px;border-radius:9px;}
.bok{background:rgba(34,197,94,.1);color:var(--green);}
.bwarn{background:rgba(245,158,11,.1);color:var(--amber);}
.berr{background:rgba(239,68,68,.1);color:var(--red);}
.srow{display:flex;align-items:center;justify-content:space-between;padding:5px 0;border-bottom:1px solid rgba(6,90,130,.06);}
.srow:last-child{border-bottom:none;}
.srow-name{font-size:11px;color:var(--slate);}
.cond-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:9px;font-size:11px;font-weight:700;}
.cond-room{background:rgba(245,158,11,.1);color:#d97706;border:1px solid rgba(245,158,11,.25);}
.cond-cool{background:rgba(96,165,250,.1);color:#2563eb;border:1px solid rgba(96,165,250,.25);}
.cond-warm{background:rgba(239,68,68,.1);color:#dc2626;border:1px solid rgba(239,68,68,.25);}

/* CHARTS AREA */
.charts{display:flex;flex-direction:column;gap:11px;}
.timeline{display:flex;gap:0;margin-bottom:2px;}
.phase{flex:1;padding:5px 6px;font-size:10px;text-align:center;font-weight:600;}
.ph-done{background:rgba(2,195,154,.13);color:var(--mint);}
.ph-active{background:var(--teal);color:#fff;}
.ph-future{background:rgba(6,90,130,.06);color:var(--light-slate);}
.phase:first-child{border-radius:6px 0 0 6px;}.phase:last-child{border-radius:0 6px 6px 0;}
.metric-row{display:grid;grid-template-columns:repeat(6,1fr);gap:8px;}
.metric-card{background:#fff;border-radius:8px;padding:10px;text-align:center;border:1px solid rgba(6,90,130,.09);box-shadow:0 1px 4px rgba(0,0,0,.04);}
.metric-val{font-size:20px;font-weight:800;color:var(--deep-blue);line-height:1;}
.metric-unit{font-size:10px;color:var(--light-slate);}
.metric-label{font-size:10px;color:var(--slate);margin-top:3px;}
.chart-row{display:grid;grid-template-columns:1fr 1fr;gap:11px;}
.chart-card{background:#fff;border-radius:9px;padding:13px;box-shadow:0 1px 5px rgba(0,0,0,.06);border:1px solid rgba(6,90,130,.09);}
.chart-card h3{font-size:11px;font-weight:700;color:var(--teal);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;}
.chart-wrap{position:relative;height:165px;}
.log-wrap{background:#fff;border-radius:9px;padding:13px;border:1px solid rgba(6,90,130,.09);box-shadow:0 1px 5px rgba(0,0,0,.06);}
.log-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:9px;}
.log-hdr-title{font-size:10px;font-weight:700;color:var(--teal);text-transform:uppercase;letter-spacing:.8px;}
.log-scroll{max-height:200px;overflow-y:auto;}
.log-table{width:100%;border-collapse:collapse;font-size:11px;}
.log-table th{background:var(--deep-blue);color:#fff;padding:5px 8px;text-align:left;font-size:10px;letter-spacing:.3px;position:sticky;top:0;}
.log-table td{padding:4px 8px;border-bottom:1px solid rgba(6,90,130,.06);}
.log-table tr:hover{background:rgba(6,90,130,.03);}
.log-sample td{background:rgba(2,195,154,.06);}
.sample-mark{color:var(--mint);font-weight:800;}

/* ── SERIAL LOG ── */
.serial-wrap{padding:14px 24px;}
.serial-hdr{display:flex;align-items:center;gap:10px;margin-bottom:12px;flex-wrap:wrap;}
.serial-hdr h2{font-size:15px;font-weight:700;color:var(--deep-blue);}
.serial-meta{font-size:11px;color:var(--light-slate);}
.run-tabs{display:flex;gap:5px;}
.rtab{padding:4px 14px;border-radius:5px;border:1px solid var(--teal);background:transparent;color:var(--teal);font-size:11px;cursor:pointer;font-weight:600;transition:.15s;}
.rtab.active{background:var(--teal);color:#fff;}
.serial-box{background:#0d1117;border-radius:8px;padding:14px;font-family:'Courier New',monospace;font-size:11px;line-height:1.65;color:#c9d1d9;height:430px;overflow-y:auto;border:1px solid rgba(6,90,130,.25);}
.st{color:#58a6ff;}.sa{color:#6e7681;}.sk{color:#79c0ff;}.sv{color:#a5d6ff;}
.ss{color:#6e7681;}.sst{color:#3fb950;font-weight:700;}.sw{color:#f0883e;}
.sh{color:#bc8cff;font-weight:700;}.sm{color:#02C39A;font-weight:700;}
.serial-sum{margin-top:12px;display:grid;grid-template-columns:repeat(4,1fr);gap:9px;}
.sum-card{background:#fff;border-radius:8px;padding:11px;border:1px solid rgba(6,90,130,.09);text-align:center;}
.sum-val{font-size:19px;font-weight:800;color:var(--deep-blue);}
.sum-lbl{font-size:10px;color:var(--light-slate);margin-top:2px;}

/* ── CONFIG ── */
.config-wrap{padding:14px 24px;display:grid;grid-template-columns:1fr 1fr;gap:18px;}
.form-group{margin-bottom:11px;}
.form-group label{display:block;font-size:11px;font-weight:600;color:var(--slate);margin-bottom:4px;}
.form-ctrl{width:100%;padding:7px 9px;border:1px solid rgba(6,90,130,.2);border-radius:5px;font-size:12px;color:var(--deep-blue);outline:none;}
.form-ctrl:focus{border-color:var(--teal);box-shadow:0 0 0 2px rgba(28,114,147,.13);}
.checkbox-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px;font-size:12px;}
.json-box{background:#0d1117;border-radius:7px;padding:12px;font-family:'Courier New',monospace;font-size:10.5px;color:#a5d6ff;height:320px;overflow-y:auto;}

/* ── EXPORT ── */
.export-wrap{padding:14px 24px;display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.exp-card{background:#fff;border-radius:9px;padding:18px;border:1px solid rgba(6,90,130,.09);box-shadow:0 1px 5px rgba(0,0,0,.06);}
.exp-card h3{font-size:13px;font-weight:700;color:var(--deep-blue);margin-bottom:5px;}
.exp-card p{font-size:11px;color:var(--light-slate);margin-bottom:13px;}
.stub-badge{background:rgba(245,158,11,.1);color:var(--amber);border:1px solid var(--amber);font-size:9px;padding:1px 7px;border-radius:8px;font-weight:700;margin-left:6px;}
</style>
</head>
<body>

<!-- NAV -->
<nav class="topnav">
  <div class="brand">
    <div class="brand-dot">AC</div>
    <div class="brand-name">Aqua<span>Cast</span></div>
    <span class="brand-sub">Mission Dashboard v0.3 — Lab Build</span>
  </div>
  <div class="nav-tabs">
    <button class="nav-tab active" onclick="showPage('live')">📡 Live View</button>
    <button class="nav-tab" onclick="showPage('serial')">🖥 Serial Log</button>
    <button class="nav-tab" onclick="showPage('config')">⚙ Config</button>
    <button class="nav-tab" onclick="showPage('export')">📦 Export</button>
  </div>
  <div class="status-pill">
    <div class="status-dot"></div>
    <span class="status-txt" id="statusTxt">READY — SELECT RUN</span>
  </div>
</nav>

<!-- MISSION BAR -->
<div class="mission-bar">
  <div>
    <div class="mission-id" id="missionId">AQ_LAB_20260211_RUNA</div>
    <div class="mission-meta">Device: <b>ESP32-LORA-01</b> &nbsp;|&nbsp; Location: <b>UW GIX Lab 203</b> &nbsp;|&nbsp; Container: <b>40 cm plastic bin</b></div>
  </div>
  <div class="run-btns">
    <label>Test Run:</label>
    <button class="run-btn active" id="rbA" onclick="switchRun('A')">Run A · Room Temp</button>
    <button class="run-btn"        id="rbB" onclick="switchRun('B')">Run B · Cool Water</button>
    <button class="run-btn"        id="rbC" onclick="switchRun('C')">Run C · Warm Water</button>
  </div>
  <div class="spacer"></div>
  <div class="owner-tag">👤 Victoria Yang</div>
  <button class="btn btn-primary" onclick="replay()">▶ Replay</button>
</div>

<!-- ALERT -->
<div class="alert-bar a-ok" id="alertBar">✅ System nominal — GPS: NO FIX (indoor lab — expected) — press ▶ Replay to stream data</div>

<!-- ===== LIVE VIEW ===== -->
<div id="page-live" class="page active">
<div class="live-layout">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="card">
      <div class="card-title">Live Readings</div>
      <div class="mm"><span class="mm-label">💧 Depth (m)</span>      <span class="mm-val" id="sDepth">—</span></div>
      <div class="mm"><span class="mm-label">🌡 Temp (°C)</span>       <span class="mm-val" id="sTemp">—</span></div>
      <div class="mm"><span class="mm-label">📊 Pressure (mbar)</span> <span class="mm-val" id="sPres">—</span></div>
      <div class="mm"><span class="mm-label">↕ dP (mbar)</span>        <span class="mm-val" id="sDp">—</span></div>
      <div class="mm"><span class="mm-label">🌊 NTU</span>              <span class="mm-val" id="sNtu">—</span></div>
      <div class="mm"><span class="mm-label">⚡ Turb Vavg (V)</span>   <span class="mm-val" id="sVavg">—</span></div>
      <div class="mm"><span class="mm-label">🔋 Battery (V)</span>     <span class="mm-val mm-ok">3.82</span></div>
      <div class="mm"><span class="mm-label">📍 GPS</span>              <span class="mm-val mm-warn">NO FIX</span></div>
      <div class="mm"><span class="mm-label">🛰 Satellites</span>       <span class="mm-val">0</span></div>
      <div class="mm"><span class="mm-label">🔁 Loop #</span>           <span class="mm-val" id="sLoop">0</span></div>
    </div>

    <div class="card">
      <div class="card-title">Actuation</div>
      <div class="mm"><span class="mm-label">Servo Motor</span>  <span class="mm-val" id="sServo">OPEN</span></div>
      <div class="mm"><span class="mm-label">Air Valve</span>    <span class="mm-val" id="sValve">OFF</span></div>
      <div class="mm"><span class="mm-label">Mode</span>         <span class="mm-val" id="sMode">AIR</span></div>
      <div class="mm"><span class="mm-label">State</span>        <span class="mm-val" id="sState">IDLE</span></div>
      <div class="mm"><span class="mm-label">Samples</span>      <span class="mm-val" id="sSamples">0 / 2</span></div>
    </div>

    <div class="card">
      <div class="card-title">Sensor Health</div>
      <div class="srow"><span class="srow-name">MS5837 (I²C 0x76)</span>    <span class="sbadge bok">OK</span></div>
      <div class="srow"><span class="srow-name">SEN0189 Turb (ADC34)</span>  <span class="sbadge bok">OK</span></div>
      <div class="srow"><span class="srow-name">NEO-6M GPS (UART)</span>     <span class="sbadge bwarn">NO FIX</span></div>
      <div class="srow"><span class="srow-name">ESP32 LoRa (SX1276)</span>   <span class="sbadge bok">−91 dBm</span></div>
      <div class="srow"><span class="srow-name">Air Valve (Relay)</span>      <span class="sbadge bok">STANDBY</span></div>
    </div>

    <div class="card">
      <div class="card-title">Test Condition</div>
      <div style="margin-bottom:8px;" id="condBadgeEl"><span class="cond-badge cond-room">🌡 Room Temp (~22°C)</span></div>
      <div class="mm"><span class="mm-label">Water Source</span>   <span style="font-size:11px;font-weight:600;" id="condSrc">Tap water, 1 hr settled</span></div>
      <div class="mm"><span class="mm-label">Container</span>      <span style="font-size:11px;font-weight:600;">40 cm plastic bin</span></div>
      <div class="mm"><span class="mm-label">Max depth target</span><span style="font-size:11px;font-weight:600;">35 cm</span></div>
      <div class="mm"><span class="mm-label">Ambient temp</span>   <span style="font-size:11px;font-weight:600;" id="condAmb">23.1°C</span></div>
    </div>
  </div>

  <!-- CHARTS AREA -->
  <div class="charts">

    <!-- PHASE TIMELINE -->
    <div class="card" style="padding:9px 13px;">
      <div class="card-title" style="margin-bottom:5px;">Mission Phase</div>
      <div class="timeline">
        <div class="phase ph-done"   id="ph0">INIT</div>
        <div class="phase ph-done"   id="ph1">READY</div>
        <div class="phase ph-future" id="ph2">DESCENT</div>
        <div class="phase ph-future" id="ph3">SAMPLING</div>
        <div class="phase ph-future" id="ph4">SURFACING</div>
        <div class="phase ph-future" id="ph5">COMPLETE</div>
      </div>
    </div>

    <!-- SUMMARY METRICS -->
    <div class="metric-row">
      <div class="metric-card"><div class="metric-val" id="mMaxDepth">—</div><div class="metric-unit">m</div><div class="metric-label">Max Depth</div></div>
      <div class="metric-card"><div class="metric-val" id="mMinTemp">—</div><div class="metric-unit">°C</div><div class="metric-label">Min Temp</div></div>
      <div class="metric-card"><div class="metric-val" id="mAvgNtu">—</div><div class="metric-unit">NTU</div><div class="metric-label">Avg Turbidity</div></div>
      <div class="metric-card"><div class="metric-val" id="mMaxPres">—</div><div class="metric-unit">mbar</div><div class="metric-label">Max Pressure</div></div>
      <div class="metric-card"><div class="metric-val" id="mLoops">0</div><div class="metric-unit">loops</div><div class="metric-label">Loops Run</div></div>
      <div class="metric-card"><div class="metric-val" id="mSamples">0</div><div class="metric-unit">/ 2</div><div class="metric-label">Samples</div></div>
    </div>

    <!-- CHART ROW 1 -->
    <div class="chart-row">
      <div class="chart-card"><h3>Depth (m) — time series</h3><div class="chart-wrap"><canvas id="cDepth"></canvas></div></div>
      <div class="chart-card"><h3>Temperature (°C) — time series</h3><div class="chart-wrap"><canvas id="cTemp"></canvas></div></div>
    </div>

    <!-- CHART ROW 2 -->
    <div class="chart-row">
      <div class="chart-card"><h3>Turbidity NTU — time series</h3><div class="chart-wrap"><canvas id="cTurb"></canvas></div></div>
      <div class="chart-card"><h3>Pressure (mbar) — time series</h3><div class="chart-wrap"><canvas id="cPres"></canvas></div></div>
    </div>

    <!-- SAMPLE LOG TABLE -->
    <div class="log-wrap">
      <div class="log-hdr">
        <span class="log-hdr-title">Sample Event Log</span>
        <span class="owner-tag">Victoria Yang</span>
      </div>
      <div class="log-scroll">
        <table class="log-table">
          <thead>
            <tr><th>#</th><th>Elapsed</th><th>Depth m</th><th>Temp °C</th><th>P mbar</th><th>dP</th><th>Vavg V</th><th>NTU</th><th>Mode</th><th>State</th><th>Servo</th><th>Valve</th></tr>
          </thead>
          <tbody id="logBody"><tr><td colspan="12" style="text-align:center;padding:18px;color:var(--light-slate);">Press ▶ Replay to stream data</td></tr></tbody>
        </table>
      </div>
    </div>

  </div>
</div>
</div>

<!-- ===== SERIAL LOG ===== -->
<div id="page-serial" class="page">
<div class="serial-wrap">
  <div class="serial-hdr">
    <h2>ESP32 Serial Monitor</h2>
    <span class="serial-meta">Baud: 115200 | Port: /dev/ttyUSB0 | Board: ESP32 NodeMCU-32S | FW: AquaCast v0.3</span>
    <div class="run-tabs">
      <button class="rtab active" id="stA" onclick="switchSerialRun('A')">Run A — Room Temp</button>
      <button class="rtab"        id="stB" onclick="switchSerialRun('B')">Run B — Cool Water</button>
      <button class="rtab"        id="stC" onclick="switchSerialRun('C')">Run C — Warm Water</button>
    </div>
    <div class="owner-tag">Victoria Yang</div>
  </div>
  <div class="serial-box" id="serialBox"></div>
  <div class="serial-sum">
    <div class="sum-card"><div class="sum-val" id="sumLoops">—</div><div class="sum-lbl">Total Loops</div></div>
    <div class="sum-card"><div class="sum-val" id="sumDepth">—</div><div class="sum-lbl">Max Depth (m)</div></div>
    <div class="sum-card"><div class="sum-val" id="sumTemp">—</div><div class="sum-lbl">Avg Temp (°C)</div></div>
    <div class="sum-card"><div class="sum-val" id="sumNtu">—</div><div class="sum-lbl">Avg NTU</div></div>
  </div>
</div>
</div>

<!-- ===== CONFIG ===== -->
<div id="page-config" class="page">
<div class="config-wrap">
  <div>
    <div class="card">
      <div class="card-title">Mission Configuration</div>
      <div class="form-group">
        <label>Mission ID</label>
        <input class="form-ctrl" id="cId" value="AQ_LAB_20260211_001"/>
      </div>
      <div class="form-group">
        <label>Target Depth 1 (m) — max 0.40 m lab</label>
        <input class="form-ctrl" type="number" id="cD1" value="0.20" min="0.05" max="0.40" step="0.01" oninput="refreshJSON()"/>
      </div>
      <div class="form-group">
        <label>Target Depth 2 (m)</label>
