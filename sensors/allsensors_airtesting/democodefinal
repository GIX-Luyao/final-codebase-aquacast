#include <Wire.h>
#include "MS5837.h"
#include <ESP32Servo.h>
#include <TinyGPSPlus.h>
#include <HardwareSerial.h>
#include <math.h>

// ============================================================
//                      PIN DEFINITIONS
// ============================================================
static const int I2C_SDA   = 41;
static const int I2C_SCL   = 42;

static const int TURB_PIN  = 4;

static const int GPS_RX    = 47; // ESP32 RX  <- GPS TX
static const int GPS_TX    = 48; // ESP32 TX  -> GPS RX (optional)

static const int RELAY_PIN = 26; // Relay control pin
static const int SERVO_PIN = 19;

// ============================================================
//                      OBJECTS
// ============================================================
MS5837 ms;
Servo  samplerServo;

TinyGPSPlus gps;
HardwareSerial GPSSerial(1);

// ============================================================
//                      CONFIG / SETTINGS
// ============================================================

// If your relay board is "active-low" (IN=LOW triggers relay), set true.
// If IN=HIGH triggers relay, set false.
static const bool RELAY_ACTIVE_LOW = false;

// Valve behavior (as you described):
// - No power to valve -> valve is OPEN (CO2 can pass)
// - Power applied -> valve is CLOSED
//
// We will implement semantics:
//   valveOpen()  = remove power (relay OFF)
//   valveClose() = apply power (relay ON)

// Keep the valve OPEN for 20~30 seconds during inflation.
static const unsigned long VALVE_OPEN_DURATION_MS = 30000; // 20000=20s, 30000=30s

// How often to print status to Serial
static const unsigned long LOG_INTERVAL_MS = 1000;

// Servo "moving" inference window for display only
static const unsigned long SERVO_MOVE_WINDOW_MS = 900;

// ============================================================
//                 SERVO ANGLE MAPPING (IMPORTANT)
// ============================================================
// Your old math produced angles >180 (216, 288). If your servo is a 180° positional servo,
// anything >180 tends to clamp at 180, so "2m doesn't move" happens.
// Solution: use an explicit lookup table within [0..180] and calibrate it.
//
// IMPORTANT:
// - These are placeholder angles to guarantee visible motion.
// - You MUST calibrate these values to match your mechanical indexing.
// - Use the "a###" manual command (e.g., a60, a120) to find exact angles.
int samplerAngleDeg(int samplerIndex) {
  // index: 1..5, (0 unused)
  static const int ANG[6] = {
    0,   // 0 (unused)
    30,  // 1m (Sampler 1)  <-- adjust after calibration
    60,  // 2m (Sampler 2)  <-- this fixes your "2m not moving" by ensuring a distinct angle
    90,  // 3m (Sampler 3)
    120, // 4m (Sampler 4)
    150  // 5m (Sampler 5)
  };

  samplerIndex = constrain(samplerIndex, 1, 5);
  return ANG[samplerIndex];
}

// ============================================================
//                      STATE MACHINE
// ============================================================
enum State {
  IDLE,      // Waiting for 's'
  RUNNING,   // Sequence executing
  DONE
};

State state = IDLE;

// Sequence timing
unsigned long seqStartMs = 0;

// Stage flags (so we trigger each action once)
bool didS1 = false;
bool didS3 = false;
bool didS5 = false;
bool didS4 = false;
bool didS2 = false;

// Valve runtime status
bool valveIsOpen = false;           // semantic: open == CO2 can pass
unsigned long valveOpenStartMs = 0;

// Servo runtime status (display only)
bool servoIsMoving = false;
int  servoTargetDeg = 0;
unsigned long servoMoveUntilMs = 0;

// Sensor init status
bool msOk = false;

// Logging
unsigned long lastLogMs = 0;

// ============================================================
//                      RELAY / VALVE HELPERS
// ============================================================
// Low-level relay write:
//   relay ON  means output triggers relay coil (depends on active low/high)
//   relay OFF means output releases relay coil
void relayOn() {
  digitalWrite(RELAY_PIN, RELAY_ACTIVE_LOW ? LOW : HIGH);
}
void relayOff() {
  digitalWrite(RELAY_PIN, RELAY_ACTIVE_LOW ? HIGH : LOW);
}

// Semantic valve control:
// - valveClose(): apply power to valve (CLOSED state)
// - valveOpen():  remove power (OPEN state, CO2 can pass)
void valveClose() {
  relayOn();            // relay ON -> power applied to valve -> valve CLOSED
  valveIsOpen = false;
}

void valveOpen() {
  relayOff();           // relay OFF -> no power -> valve OPEN
  valveIsOpen = true;
  valveOpenStartMs = millis();
}

// ============================================================
//                      SERVO HELPERS
// ============================================================
void commandServoTo(int deg) {
  deg = constrain(deg, 0, 180);
  servoTargetDeg = deg;

  samplerServo.write(deg);

  // Software-only "moving" window for display
  servoIsMoving = true;
  servoMoveUntilMs = millis() + SERVO_MOVE_WINDOW_MS;
}

// ============================================================
//                      SENSOR HELPERS
// ============================================================
float adcToVoltage(int raw) {
  return (raw / 4095.0f) * 3.3f;
}

// ============================================================
//                      CONTROL HELPERS
// ============================================================
void resetSequence() {
  valveClose();         // default: powered -> valve CLOSED
  commandServoTo(0);

  state = IDLE;
  seqStartMs = 0;

  didS1 = didS3 = didS5 = didS4 = didS2 = false;

  Serial.println();
  Serial.println("=== RESET DONE ===");
  Serial.println("Commands: 's' start, 'r' reset, 'x' emergency stop, 'a###' manual servo angle");
}

void emergencyStop() {
  // Safety: close valve immediately (apply power)
  valveClose();
  commandServoTo(0);

  state = IDLE;
  seqStartMs = 0;
  didS1 = didS3 = didS5 = didS4 = didS2 = false;

  Serial.println();
  Serial.println("!!! EMERGENCY STOP !!! Valve CLOSED, sequence stopped.");
  Serial.println("Commands: 's' start, 'r' reset, 'a###' manual servo angle");
}

// ============================================================
//                      SETUP
// ============================================================
void setup() {
  Serial.begin(115200);
  delay(1500);

  Serial.println();
  Serial.println("BOOT OK - AquaCast Sampler Controller (ESP32-S3)");
  Serial.println("Valve logic: No power = OPEN, Power applied = CLOSED");
  Serial.println("Commands: 's' start, 'r' reset, 'x' emergency stop, 'a###' servo angle");

  // Relay / valve
  pinMode(RELAY_PIN, OUTPUT);
  valveClose();  // IMPORTANT: default on power-up should be CLOSED

  // Servo
  samplerServo.setPeriodHertz(50);
  samplerServo.attach(SERVO_PIN, 500, 2500);
  commandServoTo(0);

  // I2C + MS5837
  Wire.begin(I2C_SDA, I2C_SCL);
  msOk = ms.init();
  if (!msOk) {
    Serial.println("❌ MS5837 init failed (continuing without depth)");
  } else {
    Serial.println("✅ MS5837 init OK");
    ms.setModel(MS5837::MS5837_30BA);
    ms.setFluidDensity(997); // freshwater
  }

  // ADC
  analogReadResolution(12);
  analogSetAttenuation(ADC_11db);

  // GPS
  GPSSerial.begin(9600, SERIAL_8N1, GPS_RX, GPS_TX);
  Serial.println("GPS serial started @9600");

  Serial.println("=== READY === Press 's' to start sequence.");
}

// ============================================================
//                      LOOP
// ============================================================
void loop() {
  unsigned long now = millis();

  // Update servo moving window (display only)
  if (servoIsMoving && (long)(now - servoMoveUntilMs) >= 0) {
    servoIsMoving = false;
  }

  // GPS decode
  while (GPSSerial.available()) {
    gps.encode(GPSSerial.read());
  }

  // ------------------------------------------------------------
  // Serial commands
  // ------------------------------------------------------------
  // Supported:
  //  - 's' start sequence
  //  - 'r' reset
  //  - 'x' emergency stop (close valve immediately)
  //  - 'a###' set manual servo angle (e.g., a120)
  while (Serial.available()) {
    char c = Serial.read();

    if (c == 'r' || c == 'R') {
      resetSequence();
    } else if (c == 'x' || c == 'X') {
      emergencyStop();
    } else if ((c == 's' || c == 'S') && state == IDLE) {
      state = RUNNING;
      seqStartMs = now;
      didS1 = didS3 = didS5 = didS4 = didS2 = false;

      Serial.println();
      Serial.println("=== SEQUENCE START ===");
    } else if (c == 'a' || c == 'A') {
      int deg = Serial.parseInt();     // reads the number after 'a'
      deg = constrain(deg, 0, 180);
      Serial.print("Manual servo angle -> ");
      Serial.println(deg);
      commandServoTo(deg);
    }
  }

  // ------------------------------------------------------------
  // Sensor reads (safe)
  // ------------------------------------------------------------
  float depth_m = NAN;
  float temp_c  = NAN;
  if (msOk) {
    ms.read();
    depth_m = ms.depth();
    temp_c  = ms.temperature();
  }

  int turbRaw = analogRead(TURB_PIN);
  float turbV = adcToVoltage(turbRaw);

  // ------------------------------------------------------------
  // Status logging (always prints once per second)
  // ------------------------------------------------------------
  if (now - lastLogMs >= LOG_INTERVAL_MS) {
    lastLogMs = now;

    Serial.print("[STATUS] State=");
    if (state == IDLE) Serial.print("IDLE");
    else if (state == RUNNING) Serial.print("RUNNING");
    else Serial.print("DONE");

    Serial.print(" | Depth=");
    if (isnan(depth_m)) Serial.print("NA");
    else Serial.print(depth_m, 2);
    Serial.print("m");

    Serial.print(" | Temp=");
    if (isnan(temp_c)) Serial.print("NA");
    else Serial.print(temp_c, 2);
    Serial.print("C");

    Serial.print(" | Turb=");
    Serial.print(turbV, 3);
    Serial.print("V");

    Serial.print(" | Valve=");
    Serial.print(valveIsOpen ? "OPEN" : "CLOSED");
    if (valveIsOpen) {
      Serial.print("(");
      Serial.print((now - valveOpenStartMs) / 1000);
      Serial.print("s)");
    }

    Serial.print(" | Servo=");
    if (servoIsMoving) {
      Serial.print("MOVING->");
      Serial.print(servoTargetDeg);
    } else {
      Serial.print("HOLD@");
      Serial.print(servoTargetDeg);
    }

    Serial.print(" | GPS=");
    if (gps.location.isValid()) {
      Serial.print(gps.location.lat(), 6);
      Serial.print(",");
      Serial.print(gps.location.lng(), 6);
    } else {
      Serial.print("NO FIX");
      if (gps.satellites.isValid()) {
        Serial.print(" | Sats=");
        Serial.print(gps.satellites.value());
      }
    }

    Serial.println();
  }

  // ------------------------------------------------------------
  // Sequence logic (only when running)
  // Timeline:
  //  5s  -> close sampler 1 (1m)
  // 10s  -> close sampler 3 (3m)
  // 15s  -> close sampler 5 (5m) + OPEN valve (inflate)
  // 20s  -> close sampler 4 (4m) while valve still OPEN
  // 25s  -> close sampler 2 (2m) while valve still OPEN
  // valve stays OPEN for VALVE_OPEN_DURATION_MS, then CLOSE automatically
  // done once sampler2 done and valve is CLOSED
  // ------------------------------------------------------------
  if (state != RUNNING) {
    // Still manage auto-close if someone manually opened valve (rare), but normally not needed.
    if (valveIsOpen && (now - valveOpenStartMs >= VALVE_OPEN_DURATION_MS)) {
      Serial.print("Valve auto-close after ");
      Serial.print(VALVE_OPEN_DURATION_MS / 1000);
      Serial.println("s");
      valveClose();
    }
    return;
  }

  unsigned long t = now - seqStartMs;

  if (!didS1 && t >= 5000) {
    Serial.println("Sampler 1 CLOSE (1m)");
    commandServoTo(samplerAngleDeg(1));
    didS1 = true;
  }

  if (!didS3 && t >= 10000) {
    Serial.println("Sampler 3 CLOSE (3m)");
    commandServoTo(samplerAngleDeg(3));
    didS3 = true;
  }

  if (!didS5 && t >= 15000) {
    Serial.println("Sampler 5 CLOSE (5m)");
    commandServoTo(samplerAngleDeg(5));

    Serial.print("Air Valve OPEN for ");
    Serial.print(VALVE_OPEN_DURATION_MS / 1000);
    Serial.println("s (inflate tire)");
    valveOpen();

    didS5 = true;
  }

  if (!didS4 && t >= 20000) {
    Serial.println("Sampler 4 CLOSE (4m) (valve remains OPEN)");
    commandServoTo(samplerAngleDeg(4));
    didS4 = true;
  }

  if (!didS2 && t >= 25000) {
    Serial.println("Sampler 2 CLOSE (2m) (valve remains OPEN)");
    commandServoTo(samplerAngleDeg(2));
    didS2 = true;
  }

  // Auto close valve after duration
  if (valveIsOpen && (now - valveOpenStartMs >= VALVE_OPEN_DURATION_MS)) {
    Serial.println("Air Valve CLOSE (stop inflation)");
    valveClose();
  }

  // Finish condition: sampler2 done AND valve closed
  if (didS2 && !valveIsOpen) {
    Serial.println("=== SEQUENCE DONE ===");
    Serial.println("Press 'r' to reset, then 's' to run again.");
    state = DONE;
  }
}
