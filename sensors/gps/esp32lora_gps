#include <HardwareSerial.h>
#include <TinyGPSPlus.h>

TinyGPSPlus gps;
HardwareSerial GPSSerial(1);

void setup() {
  Serial.begin(115200);
  delay(1500);
  Serial.println("\n=== GPS STATUS (TX->GPIO19) ===");
  GPSSerial.begin(9600, SERIAL_8N1, 19, -1);
}

void loop() {
  while (GPSSerial.available()) gps.encode(GPSSerial.read());

  static unsigned long last = 0;
  if (millis() - last >= 1000) {
    last = millis();

    Serial.print("Sats=");
    Serial.print(gps.satellites.isValid() ? gps.satellites.value() : 0);

    Serial.print(" | Fix=");
    Serial.print(gps.location.isValid() ? "YES" : "NO");

    Serial.print(" | Lat=");
    if (gps.location.isValid()) Serial.print(gps.location.lat(), 6);
    else Serial.print("NA");

    Serial.print(" | Lng=");
    if (gps.location.isValid()) Serial.print(gps.location.lng(), 6);
    else Serial.print("NA");

    Serial.println();
  }
}
