#include <Arduino.h>
#include <HardwareSerial.h>
#include <TinyGPSPlus.h>
#include <RadioLib.h>

// ===================== LoRa (Heltec WiFi LoRa 32 V3 / SX1262) =====================
SX1262 radio = new Module(8, 14, 12, 13);  // CS, DIO1, RST, BUSY
int loraCounter = 0;

// ===================== GPS (UART) =====================
TinyGPSPlus gps;
HardwareSerial GPSSerial(1);

// Your wiring:
// GPS RX -> ESP32 GPIO47 (ESP32 TX1)
// GPS TX -> ESP32 GPIO48 (ESP32 RX1)
static const int GPS_TX_PIN = 47;  // ESP32 TX -> GPS RX (usually not required for read-only)
static const int GPS_RX_PIN = 48;  // ESP32 RX <- GPS TX (important)
static const uint32_t GPS_BAUD = 9600;

// ===================== Timing =====================
static const uint32_t PRINT_INTERVAL_MS = 1000;
static const uint32_t NMEA_ECHO_WINDOW_MS = 12000; // echo raw NMEA for first 12s after boot

void setup() {
  Serial.begin(115200);
  delay(1200);
  while (!Serial) { delay(10); }

  Serial.println("\n=== Heltec V3: GPS Debug + LoRa Sender ===");

  // Start GPS UART
  GPSSerial.begin(GPS_BAUD, SERIAL_8N1, GPS_RX_PIN, GPS_TX_PIN);
  Serial.println("GPS UART started: Serial1 @ 9600 baud");
  Serial.println("Tip: For first 12s, raw NMEA will be echoed. You should see lines like $GPGGA / $GNRMC.");

  // Init LoRa
  int state = radio.begin(915.0);
  Serial.print("LoRa radio.begin state = ");
  Serial.println(state);

  if (state != RADIOLIB_ERR_NONE) {
    Serial.println("❌ LoRa init failed (check LoRa wiring/board/antenna)");
    while (true) delay(1000);
  }
  Serial.println("✅ LoRa ready\n");
}

void loop() {
  // 1) Read bytes from GPS UART, feed TinyGPSPlus, optionally echo raw NMEA
  static uint32_t bootMs = millis();
  while (GPSSerial.available()) {
    char c = (char)GPSSerial.read();
    gps.encode(c);

    // Echo raw NMEA for a short window to debug whether GPS is outputting data
    if (millis() - bootMs < NMEA_ECHO_WINDOW_MS) {
      Serial.write(c);
    }
  }

  // 2) Once per second: print parsed status + send over LoRa
  static uint32_t last = 0;
  if (millis() - last >= PRINT_INTERVAL_MS) {
    last = millis();

    // Quick “is data coming in?” indicator
    uint32_t chars = gps.charsProcessed();
    uint32_t sats  = gps.satellites.isValid() ? gps.satellites.value() : 0;
    bool fix       = gps.location.isValid();

    String latStr = fix ? String(gps.location.lat(), 6) : String("NA");
    String lngStr = fix ? String(gps.location.lng(), 6) : String("NA");

    // Serial debug line (local)
    Serial.print("\nGPS chars=");
    Serial.print(chars);
    Serial.print(" | fix=");
    Serial.print(fix ? "YES" : "NO");
    Serial.print(" | sats=");
    Serial.print(sats);
    Serial.print(" | lat=");
    Serial.print(latStr);
    Serial.print(" | lng=");
    Serial.println(lngStr);

    // 3) LoRa payload (compact)
    String payload = "GPS#" + String(loraCounter++) +
                     " chars=" + String(chars) +
                     " fix=" + String(fix ? 1 : 0) +
                     " sats=" + String(sats) +
                     " lat=" + latStr +
                     " lng=" + lngStr;

    int txState = radio.transmit(payload);

    Serial.print("LoRa TX state=");
    Serial.print(txState);   // 0 means success
    Serial.print(" | ");
    Serial.println(payload);
  }
}
